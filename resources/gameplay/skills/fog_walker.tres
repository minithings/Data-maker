[resource]
script = ExtResource("1_fgw")
code = "fog_walker"
name = "Kẻ Lội Sương"
description = "Sương mù không còn là rào cản. Đôi mắt xuyên thấu mây mờ, chân không chùn bước và dễ dàng bắt gặp những kỳ trân dị thảo ẩn giấu."
icon_emoji = "🌫"
category = "exploration"
prerequisites = Array[String](["pathfinder", "forager"])
level_costs = [{
"player_level": 8,
"skill_points": 4
}]
level_effects = [{
"fog_immunity": 1,
"fog_vision_bonus": 0.5,
"rare_item_chance": 0.05
}]
