script = ExtResource("1_a3neq")
code = "gourmet_cooking"
name = "Bếp Làng Danh Tiếng"
description = "Nâng tầm nhà bếp làng lên đẳng cấp mới: phối hợp nguyên liệu đặc sắc, điều chỉnh lửa theo từng món, tạo ra bữa ăn không chỉ no bụng mà còn phấn chấn tinh thần."
flavor_text = "Người ta nhớ một ngôi làng qua mùi bếp của nó — đừng để bếp làng mình tẻ nhạt."
category = "cooking"
tier = 4
