[resource]
script = ExtResource("1_a3neq")
code = "herbalism"
name = "Cây Thuốc Nam"
description = "Học nhận mặt và thu hái cây thuốc nam từ rừng và bờ ruộng. Sắc thuốc, giã lá đắp vết thương — giúp người trong làng khoẻ mạnh mà không cần lên tỉnh tìm thầy."
flavor_text = "Đằng sau mỗi bờ rào, gốc cây đều có thể là thuốc — chỉ cần người biết đọc ra."
category = "farming"
tier = 3
prerequisites = Array[String](["vegetable_farming", "irrigation"])
required_village_level = 4
gold_cost = 300
item_costs = {
"honey_jar": 5,
"wood": 20,
"stone": 10
}
children = Array[String]([])
unlocks_skills = Array[String](["herbalist"])
production_buffs = {
"herb_yield": 0.3,
"medicine_effectiveness": 0.2
}
unlocks_knowledges = Array[String](["knowledge_herbalism"])
