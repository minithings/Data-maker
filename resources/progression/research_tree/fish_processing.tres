[resource]
script = ExtResource("1_a3neq")
code = "fish_processing"
name = "Chế Biến Thuỷ Sản"
description = "Nắm vững cách làm sạch, ướp gia vị và chế biến cá đồng thành các món ngon: canh chua, cá kho tộ, cá hấp gừng. Biến mẻ câu hàng ngày thành nguồn thu đáng kể."
flavor_text = "Cá không tự đến bàn ăn — nhưng đôi bàn tay khéo có thể biến nó thành thứ giá trị gấp đôi."
category = "fishing"
tier = 3
prerequisites = Array[String](["advanced_fishing"])
required_village_level = 4
gold_cost = 250
item_costs = {
"salmon": 3,
"catfish": 5,
"stone": 15
}
children = Array[String]([])
unlocks_recipes = Array[String](["recipe_fish_soup"])
