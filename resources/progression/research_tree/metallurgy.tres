script = ExtResource("1_a3neq")
code = "metallurgy"
name = "Nghề Đúc Sắt"
description = "Dựng lò rèn, học cách đãi quặng và nung luyện sắt thô. Từ đây làng bước vào thời đại công cụ mới — bền hơn, bén hơn, làm được nhiều hơn."
flavor_text = "Tiếng búa rèn vang trong đêm — làng nào có lò rèn, làng đó không sợ đói rét."
category = "industry"
tier = 2
